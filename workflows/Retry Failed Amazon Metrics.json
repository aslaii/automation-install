        "jsCode": "function normalizeMetricKeys(raw) {\n  if (Array.isArray(raw)) {\n    return raw.map((value) => String(value).trim()).filter(Boolean);\n  }\n  if (typeof raw === 'string') {\n    return raw.split(',').map((value) => value.trim()).filter(Boolean);\n  }\n  return [];\n}\n\nconst state = $('Prepare Retry Request').first().json;\nconst payload = $input.first().json || {};\nconst summary = payload.finalSummary || payload.summary || [];\nconst failedMetricKeys = [...new Set(normalizeMetricKeys(payload.remainingFailedMetricKeys ?? payload.failedMetricKeys))];\nconst attempts = [\n  ...(state.attempts || []),\n  {\n    retryRound: state.retryRound,\n    includeList: state.INCLUDE_LIST || '',\n    failedMetricKeys,\n    summary,\n  },\n];\n\nreturn [{\n  json: {\n    ...state,\n    attempts,\n    finalSummary: summary,\n    remainingFailedMetricKeys: failedMetricKeys,\n    completed: failedMetricKeys.length === 0,\n  },\n}];"
