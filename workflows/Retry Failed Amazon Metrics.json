      "parameters": {
        "jsCode": "function normalizeMetricKeys(raw) {\n  if (Array.isArray(raw)) {\n    return raw.map((value) => String(value).trim()).filter(Boolean);\n  }\n  if (typeof raw === 'string') {\n    return raw.split(',').map((value) => value.trim()).filter(Boolean);\n  }\n  return [];\n}\n\nconst input = $input.first().json || {};\nconst remainingFailedMetricKeys = [...new Set(normalizeMetricKeys(input.FAILED_METRIC_KEYS ?? input.failedMetricKeys))];\nconst maxRetries = Math.max(1, Number(input.MAX_RETRIES || input.maxRetries || 3));\nconst retryRound = Math.max(1, Number(input.RETRY_ROUND || input.retryRound || 1));\n\nreturn [{\n  json: {\n    '\u2705START_DATE': input['\u2705START_DATE'],\n    '\u2705END_DATE': input['\u2705END_DATE'],\n    '\u2705SPREADSHEET_URL_OR_ID': input['\u2705SPREADSHEET_URL_OR_ID'],\n    '\u2705SPREADSHEET_ID': input['\u2705SPREADSHEET_ID'],\n    '\u2705SHEET_NAME': input['\u2705SHEET_NAME'],\n    '\u2705RANGE': input['\u2705RANGE'],\n    '\u2705COLUMNS': input['\u2705COLUMNS'],\n    '\u2705AMAZON_MARKETPLACE_ID': input['\u2705AMAZON_MARKETPLACE_ID'],\n    '\u2705AMAZON_ADS_CLIENT_ID': input['\u2705AMAZON_ADS_CLIENT_ID'],\n    '\u2705AMAZON_ADS_CLIENT_SECRET': input['\u2705AMAZON_ADS_CLIENT_SECRET'],\n    '\u2705AMAZON_ADS_REFRESH_TOKEN': input['\u2705AMAZON_ADS_REFRESH_TOKEN'],\n    '\u2705AMAZON_ADS_PROFILE_ID': input['\u2705AMAZON_ADS_PROFILE_ID'],\n    '\u2705AMAZON_SP_CLIENT_ID': input['\u2705AMAZON_SP_CLIENT_ID'],\n    '\u2705AMAZON_SP_CLIENT_SECRET: ': input['\u2705AMAZON_SP_CLIENT_SECRET: '],\n    '\u2705AMAZON_SP_REFRESH_TOKEN': input['\u2705AMAZON_SP_REFRESH_TOKEN'],\n    '\u2705GOOGLE_SERVICE_ACCOUNT_EMAIL': input['\u2705GOOGLE_SERVICE_ACCOUNT_EMAIL'],\n    '\u2705GOOGLE_PRIVATE_KEY': input['\u2705GOOGLE_PRIVATE_KEY'],\n    '\u2705GOOGLE_SCOPE': input['\u2705GOOGLE_SCOPE'],\n    remainingFailedMetricKeys,\n    retryRound,\n    maxRetries,\n    attempts: [],\n    finalSummary: Array.isArray(input.summary) ? input.summary : [],\n    completed: remainingFailedMetricKeys.length === 0,\n  },\n}];"
