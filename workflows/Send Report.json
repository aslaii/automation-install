      "id": "46964e0e-29f3-44b2-8000-b9dab9f821ea",
      "name": "Export Snapshot PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1136,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst payload = $('Set Credentials').first().json;\nconst pdfBinary = $input.first().binary?.pdfData;\nif (!pdfBinary) throw new Error('Expected exported PDF binary at item.binary.pdfData');\nconst reportDate = String(payload['✅reportDate'] || '').replace(/-/g, '_');\nconst baseName = String(payload['✅sheetName'] || 'SNAPSHOT').replace(/[^a-zA-Z0-9]+/g, '_').replace(/^_+|_+$/g, '').toUpperCase() + '_' + reportDate;\nconst tempRoot = (payload['✅localTempRoot'] || '/tmp').replace(/[\\\\/]+$/, '');\nconst outputRoot = (payload['✅snapshotOutputRoot'] || tempRoot).replace(/[\\\\/]+$/, '');\nfs.mkdirSync(tempRoot, { recursive: true });\nfs.mkdirSync(outputRoot, { recursive: true });\nconst pdfFileName = baseName + '.pdf';\nconst pngFileName = baseName + '.png';\nconst pdfPath = tempRoot + '/' + pdfFileName;\nconst pngPrefix = outputRoot + '/' + baseName;\nconst pngPath = outputRoot + '/' + pngFileName;\nconst pngDir = outputRoot;\nif (fs.existsSync(pdfPath)) fs.unlinkSync(pdfPath);\nif (fs.existsSync(pngPath)) fs.unlinkSync(pngPath);\nconst pdfBuffer = await this.helpers.getBinaryDataBuffer(0, 'pdfData');\nfs.writeFileSync(pdfPath, pdfBuffer);\nreturn [{ json: { baseName, pdfFileName, pngFileName, pdfPath, pngPrefix, pngPath, pngDir, reportDate: payload['✅reportDate'], source: payload['✅source'], message: payload['✅message'], sheetName: payload['✅sheetName'] } }];"
      },
      "id": "25c0a9a8-5ca0-473c-961a-887fedf9b3e0",
      "name": "Prepare File Paths",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        352
      ]
    },
    {
      "parameters": {
        "command": "=mkdir -p \"{{ $json.pngDir }}\" && \"{{ $(\"Set Credentials\").first().json[\"✅pdfRendererBinary\"] }}\" -png -f 1 -singlefile \"{{ $json.pdfPath }}\" \"{{ $json.pngPrefix }}\""
      },
      "id": "6c144d0d-1a1d-4a95-91d8-9014841b169d",
      "name": "Render PDF To PNG",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1584,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst meta = $('Prepare File Paths').first().json;\nif (!fs.existsSync(meta.pdfPath)) throw new Error('PDF output not found: ' + meta.pdfPath);\nif (!fs.existsSync(meta.pngPath)) throw new Error('PNG output not found: ' + meta.pngPath);\nconst pdfBuffer = fs.readFileSync(meta.pdfPath);\nconst pngBuffer = fs.readFileSync(meta.pngPath);\nconst pdfStats = fs.statSync(meta.pdfPath);\nconst pngStats = fs.statSync(meta.pngPath);\nconst pdfBinary = await this.helpers.prepareBinaryData(pdfBuffer, meta.pdfFileName, 'application/pdf');\nconst imageBinary = await this.helpers.prepareBinaryData(pngBuffer, meta.pngFileName, 'image/png');\nconst caption = meta.message + ' - ' + meta.source + ' - Date: ' + meta.reportDate;\nreturn [{ json: { ...meta, pdfSize: pdfStats.size, pngSize: pngStats.size, slackInitialComment: caption, telegramCaption: caption }, binary: { pdf: pdfBinary, image: imageBinary } }];"
      },
