      "id": "b0c7f631-9bbe-4558-8d94-a6c074a7229e",
      "name": "Set Credentials",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        464,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nfunction b64urlFromString(str) { return Buffer.from(str, 'utf8').toString('base64').replace(/=/g, '').replace(/\\+/g, '-').replace(/\\//g, '_'); }\nconst input = $input.first().json;\nconst serviceAccountEmail = input['✅googleClientEmail'];\nconst privateKeyPem = String(input['✅googlePrivateKey'] || '').replace(/\\\\n/g, '\\n');\nconst scope = input['✅googleScope'] || 'https://www.googleapis.com/auth/drive.readonly https://www.googleapis.com/auth/spreadsheets.readonly';\nif (!serviceAccountEmail || !privateKeyPem) throw new Error('Missing googleClientEmail or googlePrivateKey');\nconst now = Math.floor(Date.now() / 1000);\nconst header = { alg: 'RS256', typ: 'JWT' };\nconst payload = { iss: serviceAccountEmail, scope, aud: 'https://oauth2.googleapis.com/token', iat: now, exp: now + 3600 };\nconst signingInput = b64urlFromString(JSON.stringify(header)) + '.' + b64urlFromString(JSON.stringify(payload));\nconst signer = crypto.createSign('RSA-SHA256');\nsigner.update(signingInput);\nsigner.end();\nconst signature = signer.sign(privateKeyPem, 'base64').replace(/=/g, '').replace(/\\+/g, '-').replace(/\\//g, '_');\nreturn [{ json: { ...input, assertion: signingInput + '.' + signature } }];"
      },
      "id": "1d37104c-c3e9-494e-b11a-7c90c25d7ede",
