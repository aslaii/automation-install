    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst values = typeof item.json === 'object' && item.json !== null ? Object.values(item.json) : [item.json];\nconst text = values.map((value) => String(value)).join(' ').trim();\nif (!text.startsWith('OK')) throw new Error('Slack binary upload failed: ' + text);\nconst meta = $('Extract Slack Upload Meta').first().json;\nreturn [{ json: { ...meta, uploadResponse: text.substring(0, 200), uploadTransport: 'http-request-multipart' } }];"
      },
