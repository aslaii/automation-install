    {
      "id": "40ab5b65-ab0d-48fc-aa52-b1921d6773d1",
      "name": "Build Group Registry",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        320
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const input = $input.first().json;\nconst groups = [\n  { groupKey: 'ads', workflowId: 'vmOB9dWgN8q6LJVk', metricKeys: ['ads_spend', 'ctr', 'sales_ppc', 'clicks', 'units_ppc'] },\n  { groupKey: 'sp', workflowId: 'lI6VdPxTKRYvgIUn', metricKeys: ['refunds', 'sales_organic', 'units_organic', 'reversal_reimbursement'] },\n  { groupKey: 'special', workflowId: 'JcjQO7vgmt1m0JRa', metricKeys: ['bsr', 'fba_fbm_stock', 'fba_per_unit_fulfillment_fee'] },\n];\nconst selectedMetrics = [...new Set(String(input.INCLUDE_LIST || '').split(',').map((value) => value.trim().toLowerCase()).filter(Boolean))];\nconst runAll = selectedMetrics.length === 0;\nreturn groups.map((group) => {\n  const requestedMetrics = runAll ? [...group.metricKeys] : selectedMetrics.filter((metricKey) => group.metricKeys.includes(metricKey));\n  return {\n    json: {\n      '✅START_DATE': input['✅START_DATE'],\n      '✅END_DATE': input['✅END_DATE'],\n      INCLUDE_LIST: requestedMetrics.join(','),\n      groupKey: group.groupKey,\n      workflowId: group.workflowId,\n      metricKeys: group.metricKeys,\n      selectedMetrics: requestedMetrics,\n      shouldRun: runAll || requestedMetrics.length > 0,\n      groupStartedAt: new Date().toISOString(),\n    },\n  };\n});"
      }
    },
    {
      "id": "7cecb546-e5f1-453e-a6de-6bb85fb71868",
      "name": "Final Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2240,
        320
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const results = $('Record Group Result').all().map((item) => item.json);\nconst groups = results.map((item) => item.group).filter(Boolean);\nconst summary = results.flatMap((item) => Array.isArray(item.summary) ? item.summary : []);\nconst totals = summary.reduce((acc, item) => { acc.total += 1; acc[item.status] = (acc[item.status] || 0) + 1; return acc; }, { total: 0, success: 0, failed: 0, skipped: 0 });\nreturn [{ json: { groups, summary, totals } }];"
      }
    },
