    {
      "id": "8a827e51-1c65-4e1a-bfb7-bb29c33e9669",
      "name": "Record Group Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1952,
        320
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const current = $('If Should Run Group').item.json || $json || {};\nconst payload = $json || {};\nconst finishedAt = new Date().toISOString();\nconst allMetrics = Array.isArray(current.metricKeys) ? current.metricKeys : [];\nconst selected = Array.isArray(current.selectedMetrics) ? current.selectedMetrics : [];\nfunction buildSkippedSummary() {\n  return allMetrics.map((metricKey) => ({ groupKey: current.groupKey, metricKey, status: 'skipped', errorMessage: null, startedAt: null, finishedAt }));\n}\nif (!current.shouldRun) {\n  return { json: { group: { groupKey: current.groupKey, status: 'skipped', selectedMetrics: [], errorMessage: null, startedAt: null, finishedAt }, summary: buildSkippedSummary() } };\n}\nconst executionError = payload.error || payload.execution?.error || null;\nconst rawSummary = Array.isArray(payload.summary) ? payload.summary : [];\nconst summary = rawSummary.length ? rawSummary.map((item) => ({ groupKey: current.groupKey, metricKey: item.metricKey, status: item.status || (executionError ? 'failed' : 'success'), errorMessage: item.errorMessage ?? (executionError ? String(executionError.message || payload.message || 'Group workflow failed') : null), startedAt: item.startedAt ?? current.groupStartedAt ?? null, finishedAt: item.finishedAt ?? finishedAt })) : allMetrics.map((metricKey) => ({ groupKey: current.groupKey, metricKey, status: selected.includes(metricKey) ? (executionError ? 'failed' : 'success') : 'skipped', errorMessage: selected.includes(metricKey) && executionError ? String(executionError.message || payload.message || 'Group workflow failed') : null, startedAt: selected.includes(metricKey) ? current.groupStartedAt ?? null : null, finishedAt }));\nconst groupStatus = executionError ? 'failed' : (payload.groups?.[0]?.status || (summary.some((item) => item.status === 'failed') ? 'failed' : summary.some((item) => item.status === 'success') ? 'success' : 'skipped'));\nconst groupErrorMessage = executionError ? String(executionError.message || payload.message || 'Group workflow failed') : (payload.groups?.[0]?.errorMessage ?? null);\nreturn { json: { group: { groupKey: current.groupKey, status: groupStatus, selectedMetrics: selected, errorMessage: groupErrorMessage, startedAt: payload.groups?.[0]?.startedAt || current.groupStartedAt || null, finishedAt: payload.groups?.[0]?.finishedAt || finishedAt }, summary } };"
      }
    },
