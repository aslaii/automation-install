    {
      "id": "build-auth-url",
      "name": "Build Auth URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        240
      ],
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst encode = (v) => encodeURIComponent(String(v || ''));\nconst query = [\n  ['application_id', input.clientId || ''],\n  ['state', input.state || 'amazon-ads-refresh-token'],\n  ['redirect_uri', input.redirectUri || ''],\n  ['scope', input.scope || 'advertising::campaign_management'],\n  ['response_type', 'code'],\n].map(([k, v]) => `${encode(k)}=${encode(v)}`).join('&');\n\nreturn [{\n  json: {\n    ...input,\n    authorizationUrl: `https://www.amazon.com/ap/oa?${query}`,\n    instructions: 'Open authorizationUrl, approve app, copy returned code into authorizationCode, run workflow again.',\n  },\n}];"
      }
    },
    {
      "id": "has-code",
      "name": "Has Code",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        480,
        240
      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 3,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ String($json.authorizationCode || '').trim() }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              },
              "id": "condition-1776131112903-kxvjgjb3l"
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "no-code-yet",
      "name": "No Code Yet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        120
      ],
      "parameters": {
        "jsCode": "return [{ json: { status: 'needs_authorization_code', authorizationUrl: $json.authorizationUrl, redirectUri: $json.redirectUri, scope: $json.scope, instructions: ['1. Open authorizationUrl in browser.','2. Sign in and approve Amazon Ads app.','3. Copy ?code=... from redirect URL.','4. Paste code into Set OAuth Inputs.authorizationCode.','5. Execute workflow again.'] } }];"
      }
    },
    {
      "id": "exchange-code",
      "name": "Exchange Auth Code for Tokens",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
