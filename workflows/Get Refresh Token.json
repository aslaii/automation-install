            },
            {
              "name": "redirect_uri",
              "value": "={{ $json.redirectUri }}"
            },
            {
              "name": "client_id",
              "value": "={{ $json.clientId }}"
            },
            {
              "name": "client_secret",
              "value": "={{ $json.clientSecret }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "format-result",
      "name": "Format Token Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        360
      ],
      "parameters": {
        "jsCode": "return [{ json: { accessToken: $json.access_token || null, refreshToken: $json.refresh_token || null, tokenType: $json.token_type || null, expiresIn: $json.expires_in || null, scope: $json.scope || null, note: 'Store refreshToken securely. Do not commit it.' } }];"
      }
    }
