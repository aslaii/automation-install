      "id": "9f1d44bc-0b29-4df7-8ee9-2a03f4bb3390",
      "name": "Slack Get Upload URL",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1584,
        416
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nif (!input.ok || !input.upload_url || !input.file_id) {\n  throw new Error(`Slack getUploadURLExternal failed: ${input.error || 'unknown_error'}`);\n}\nreturn [{ json: { uploadUrl: input.upload_url, fileId: input.file_id } }];"
      },
      "id": "53ed9106-3e4e-48ab-abed-e4651c1abc93",
      "name": "Extract Slack Upload Meta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1808,
        416
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst url = item.json.uploadUrl;\nif (!item.binary?.file) throw new Error('No binary named \"file\"');\nconst buf = await this.helpers.getBinaryDataBuffer(0, 'file');\n\n// Verify PDF header\nconst header = buf.slice(0, 5).toString('ascii');\nconst isPdf = header === '%PDF-';\n\n// Upload raw binary - only get the body as string, no full response\nconst resp = await this.helpers.httpRequest({\n  method: 'POST',\n  url: url,\n  body: buf,\n  headers: {\n    'Content-Type': 'application/octet-stream',\n    'Content-Length': String(buf.length),\n  },\n  json: false,\n});\n\nreturn [{json:{\n  uploadResponse: String(resp || '').substring(0, 200),\n  bytesUploaded: buf.length,\n  pdfHeaderValid: isPdf,\n  pdfHeader: header,\n}}];"
      },
      "id": "52a62ffe-c8ec-44b0-8596-ed3e4fdebd9e",
      "name": "Slack Upload Binary",
