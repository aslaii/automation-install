    {
      "parameters": {
        "jsCode": "const payload = $('Set Credentials').first().json;\nconst item = $input.first();\nconst pdfBinary = item.binary?.pdfData;\n\nif (!pdfBinary) {\n  throw new Error('Expected exported PDF binary at item.binary.pdfData');\n}\n\n// Get the actual buffer size\nconst buf = await this.helpers.getBinaryDataBuffer(0, 'pdfData');\n\nreturn [{\n  json: {\n    fileName: payload['✅sheetName'] + '-' + payload['✅reportDate'] + '.pdf',\n    reportDate: payload['✅reportDate'],\n    source: payload['✅source'],\n    message: payload['✅message'],\n    sheetName: payload['✅sheetName'],\n    fileSize: buf.length,\n  },\n  binary: {\n    file: pdfBinary,\n  },\n}];"
      },
